class Solution {
    public boolean wifiRange(String s, int x) {
        int max = -1;
        int n = s.length();

        for (int i = 0; i < n; i++) {

            if (s.charAt(i) == '1') {

                if (i - x > max + 1) {
                    return false;
                }

                max = i + x;
            }
        }

        return max >= n - 1;
    }
}